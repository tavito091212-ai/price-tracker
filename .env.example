# Copiar este archivo a .env y llenar con tus valores reales
# NO subir .env a GitHub - ya está en .gitignore

# Discord Webhook para notificaciones
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_TOKEN

# Odds API - Cuotas deportivas
# Registrarse en: https://api.odds-api.com
ODDS_API_KEY=your_odds_api_key_here

# Amadeus - Precios de vuelos
# Registrarse en: https://developer.amadeus.com
AMADEUS_CLIENT_ID=your_amadeus_client_id
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret

# Opcional: Game Pass API (scraping funciona sin esto)
GAMEPASS_API_KEY=your_gamepass_api_key

# Opcional: SerpAPI para vuelos por Google Flights
SERPAPI_KEY=your_serpapi_key

# Opcional: Keepa para precios de Amazon históricos
KEEPA_API_KEY=your_keepa_api_key

# WhatsApp (si quieres usar)
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_token
WHATSAPP_TO=your_recipient_number

# Email (si quieres usar SMTP)
SMTP_PASSWORD=your_gmail_app_password
